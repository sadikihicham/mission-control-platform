  "components": {
    "schemas": {
      "ActivityOut": {
        "properties": {
          "type": {
            "type": "string",
            "title": "Type"
          },
          "state": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "State"
          },
          "task": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Task"
          },
          "progress": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Progress"
          },
          "created_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "type"
        ],
        "title": "ActivityOut"
      },
      "AgentOut": {
        "properties": {
          "agent": {
            "type": "string",
            "title": "Agent"
          },
          "state": {
            "type": "string",
            "title": "State"
          },
          "task": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Task"
          },
          "module": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Module"
          },
          "label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Label"
          },
          "branch": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Branch"
          },
          "blocker": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Blocker"
          },
          "progress": {
            "type": "integer",
            "title": "Progress",
            "default": 0
          },
          "tasks_done": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tasks Done"
          },
          "tasks_total": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tasks Total"
          },
          "updated_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Updated At"
          },
          "age_seconds": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Age Seconds"
          },
          "token_issued_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Token Issued At"
          }
        },
        "type": "object",
        "required": [
          "agent",
          "state"
        ],
        "title": "AgentOut"
      },
      "Capability": {
        "type": "string",
        "enum": [
          "view",
          "operate",
          "manage_agents",
          "manage_projects",
          "approve",
          "view_costs",
          "admin"
        ],
        "title": "Capability",
        "description": "Capacités minimales du module (schéma solution §4 `HostPermissionPort`)."
      },
      "DashboardStats": {
        "properties": {
          "agents_total": {
            "type": "integer",
            "title": "Agents Total",
            "default": 0
          },
          "agents_active": {
            "type": "integer",
            "title": "Agents Active",
            "default": 0
          },
          "agents_blocked": {
            "type": "integer",
            "title": "Agents Blocked",
            "default": 0
          },
          "agents_stale": {
            "type": "integer",
            "title": "Agents Stale",
            "default": 0
          },
          "agents_done": {
            "type": "integer",
            "title": "Agents Done",
            "default": 0
          },
          "agents_error": {
            "type": "integer",
            "title": "Agents Error",
            "default": 0
          },
          "overall_progress": {
            "type": "integer",
            "title": "Overall Progress",
            "default": 0
          }
        },
        "type": "object",
        "title": "DashboardStats"
      },
      "ForgotPasswordIn": {
        "properties": {
