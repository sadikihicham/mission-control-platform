FROM node:20-slim AS base
WORKDIR /app

# Dépendances
FROM base AS deps
COPY apps/web/package.json ./
RUN npm install

# Build
FROM base AS builder
ARG NEXT_PUBLIC_API_URL=http://localhost:8008
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
COPY --from=deps /app/node_modules ./node_modules
COPY apps/web ./
RUN npm run build

# Runtime (Next standalone)
FROM base AS runner
ENV NODE_ENV=production
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
# Next.js standalone n'inclut PAS public/ (seulement les fichiers tracés) — doit être copié à part,
# sinon toutes les images statiques (logos, favicons servis via /public) répondent 404 en prod.
COPY --from=builder /app/public ./public
EXPOSE 3000
HEALTHCHECK --interval=10s --timeout=3s --retries=5 \
    CMD node -e "require('http').get('http://localhost:3000',r=>process.exit(r.statusCode<500?0:1)).on('error',()=>process.exit(1))"
CMD ["node", "server.js"]
