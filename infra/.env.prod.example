# Copier en infra/.env.prod (gitignoré) et mettre de VRAIES valeurs. Chargé explicitement au
# déploiement prod — voir docs/DEPLOY_FRONTED.md. Ne remplace PAS infra/.env (dev, valeurs faibles
# volontaires).

# Génère avec : python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-strong-random-64-hex-chars
MC_INGEST_TOKEN=change-me-strong-random-ingest-token

# Génère avec : openssl rand -hex 24 (PAS -base64 : l'alphabet base64 contient `/` et `+`,
# des délimiteurs réservés qui cassent le parsing de DATABASE_URL une fois interpolés dedans)
POSTGRES_PASSWORD=change-me-strong-db-password

# --- Pont avec la plateforme hôte SGI (ADR-0010 / ADR-0011) — OPTIONNEL ---
# Laisser VIDE tant que le pont n'est pas activé : les conséquences sont fail-closed et explicites,
# jamais silencieuses. Un déploiement qui n'utilise pas le pont n'a RIEN à poser ici.
#
# Webhook entrant SGI (`POST /integrations/sgi/subscription-events`, bascule de
# `mc_installations.status`). Sa route est montée sans condition et n'a pas d'autre authentification
# que ce secret. VIDE ⇒ route désactivée (503). Posé ⇒ route active, et la valeur DOIT être
# rigoureusement identique au `SGI_WEBHOOK_SECRET` de SGI (sinon 401 ici, échec SILENCIEUX là-bas).
# Génère avec : openssl rand -base64 48
SGI_WEBHOOK_SECRET=

# Adaptateur d'identité hôte : `local` (défaut) ou `jwt` (valide directement les JWT SGI).
MC_HOST_ADAPTER=local
# Requis UNIQUEMENT si MC_HOST_ADAPTER=jwt — sinon l'API refuse de démarrer. C'est le `JWT_SECRET`
# de SGI, pas celui de ce service.
SGI_JWT_SECRET=
